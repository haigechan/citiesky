<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyFirst Fruit Coloring Book | Author Haige</title>
    <style>
        :root { --amazon: #FF9900; --video: #eb4d4b; --audio: #6c5ce7; }
        body { font-family: -apple-system, sans-serif; display: flex; flex-direction: column; align-items: center; background: #fdfdfd; padding: 40px 20px; text-align: center; }
        .cover { width: 180px; border-radius: 12px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); margin-bottom: 20px; }
        .btn { display: block; text-decoration: none; padding: 18px; margin: 12px auto; border-radius: 50px; font-weight: bold; width: 100%; max-width: 300px; color: white; transition: 0.3s; }
        .btn:active { transform: scale(0.98); }
        #audio-box { display: none; margin-top: 20px; background: #f1f2f6; padding: 15px; border-radius: 15px; width: 100%; max-width: 300px; }
        audio { width: 100%; }
    </style>
</head>
<body>
    <img src="cover.jpg" class="cover" alt="MyFirst Fruit Coloring Book">
    <h1>MyFirst Fruit Coloring Book</h1>
    
    <a href="https://www.amazon.com/dp/B0GVYGDSNV" class="btn" style="background:var(--amazon)" target="_blank">🛒 Buy on Amazon</a>
    <a href="https://www.instagram.com/p/DWrCfjkAj_g/" class="btn" style="background:var(--video)" target="_blank">📺 Watch Trailer</a>
    <div class="btn" style="background:var(--audio); cursor:pointer;" onclick="document.getElementById('audio-box').style.display='block'">🎧 Listen to Story</div>

    <div id="audio-box">
        <audio controls controlsList="nodownload"><source src="mia_audio.mp3" type="audio/mpeg"></audio>
    </div>
</body>
</html>
